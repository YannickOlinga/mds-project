# Copier vers backend/.env et renseigner.
# Sans DATABASE_URL, Django utilise SQLite (db.sqlite3) en local.

# --- Base Postgres Supabase (projet "perinea") ---
# Dashboard Supabase > bouton "Connect" > onglet "ORM" / "psql".
# Utilise de préférence la connexion "Session pooler" (port 5432, compatible IPv4).
# Remplace [PASSWORD] par le mot de passe de la base (Connect > Database password).
#
# Exemple (Session pooler) :
# DATABASE_URL=postgresql://postgres.mwspsibzxhsjitkuisxy:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
#
# Exemple (connexion directe) :
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.mwspsibzxhsjitkuisxy.supabase.co:5432/postgres
DATABASE_URL=

# --- Django (optionnel) ---
# DJANGO_SECRET_KEY=change-me-en-prod
# DJANGO_DEBUG=True
