# Copier vers .env pour surcharger (optionnel).
# Sans .env, l'IP locale est détectée automatiquement au lancement d'Expo.

# URL complète (prioritaire)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.12:8000

# Ou host + port séparés (construit http://HOST:PORT)
# EXPO_PUBLIC_API_HOST=192.168.1.12
# EXPO_PUBLIC_API_PORT=8000
