// MPD - Modele Physique de Donnees (Postgres / Supabase) - Perinea
digraph MPD {
  graph [rankdir=LR, splines=ortho, nodesep=0.5, ranksep=1.4, fontname="Courier", bgcolor="white", label="MPD - Modele Physique de Donnees (PostgreSQL / Supabase)", labelloc="t", fontsize=20, fontname="Helvetica"];
  node  [shape=plaintext, fontname="Courier"];
  edge  [arrowhead=crow, dir=both, arrowtail=odot, color="#7C3AED", penwidth=1.3];

  auth_user [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#2563EB"><font color="white"><b>auth_user</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">username</td><td align="left">VARCHAR(150) UNIQUE</td></tr>
      <tr><td align="left">email</td><td align="left">VARCHAR(254)</td></tr>
      <tr><td align="left">password</td><td align="left">VARCHAR(128)</td></tr>
    </table>>];

  api_profile [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#2563EB"><font color="white"><b>api_profile</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">user_id</td><td align="left">BIGINT FK NULL</td></tr>
      <tr><td align="left">name</td><td align="left">VARCHAR(120)</td></tr>
      <tr><td align="left">email</td><td align="left">VARCHAR(254)</td></tr>
      <tr><td align="left">age</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">objective</td><td align="left">VARCHAR(255)</td></tr>
      <tr><td align="left">level_key</td><td align="left">VARCHAR(32)</td></tr>
      <tr><td align="left">symptoms</td><td align="left">JSONB</td></tr>
      <tr><td align="left">has_probe</td><td align="left">BOOLEAN NULL</td></tr>
      <tr><td align="left">onboarding_completed</td><td align="left">BOOLEAN</td></tr>
      <tr><td align="left">monthly_goal_sessions_target</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">created_at</td><td align="left">TIMESTAMPTZ</td></tr>
    </table>>];

  api_devicestatus [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#2563EB"><font color="white"><b>api_devicestatus</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">profile_id</td><td align="left">BIGINT FK UNIQUE</td></tr>
      <tr><td align="left">device_name</td><td align="left">VARCHAR(120)</td></tr>
      <tr><td align="left">battery_pct</td><td align="left">SMALLINT</td></tr>
      <tr><td align="left">signal_level</td><td align="left">VARCHAR(32)</td></tr>
      <tr><td align="left">connected</td><td align="left">BOOLEAN</td></tr>
      <tr><td align="left">updated_at</td><td align="left">TIMESTAMPTZ</td></tr>
    </table>>];

  api_session [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#2563EB"><font color="white"><b>api_session</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">profile_id</td><td align="left">BIGINT FK</td></tr>
      <tr><td align="left">title</td><td align="left">VARCHAR(150)</td></tr>
      <tr><td align="left">level_key</td><td align="left">VARCHAR(32)</td></tr>
      <tr><td align="left">duration_minutes</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">duration_seconds</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">exercises_count</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">started_at</td><td align="left">TIMESTAMPTZ</td></tr>
    </table>>];

  api_userachievement [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#D97706"><font color="white"><b>api_userachievement</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">profile_id</td><td align="left">BIGINT FK</td></tr>
      <tr><td align="left">achievement_id</td><td align="left">BIGINT FK</td></tr>
      <tr><td align="left">earned</td><td align="left">BOOLEAN</td></tr>
      <tr><td align="left">earned_at</td><td align="left">TIMESTAMPTZ NULL</td></tr>
      <tr><td colspan="2" align="left">UNIQUE(profile_id, achievement_id)</td></tr>
    </table>>];

  api_achievementtemplate [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#16A34A"><font color="white"><b>api_achievementtemplate</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">code</td><td align="left">VARCHAR(64) UNIQUE</td></tr>
      <tr><td align="left">title</td><td align="left">VARCHAR(120)</td></tr>
      <tr><td align="left">description</td><td align="left">VARCHAR(255)</td></tr>
      <tr><td align="left">icon</td><td align="left">VARCHAR(16)</td></tr>
    </table>>];

  api_exercisetemplate [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#16A34A"><font color="white"><b>api_exercisetemplate</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">level_key</td><td align="left">VARCHAR(32)</td></tr>
      <tr><td align="left">name</td><td align="left">VARCHAR(150)</td></tr>
      <tr><td align="left">description</td><td align="left">TEXT</td></tr>
      <tr><td align="left">icon</td><td align="left">VARCHAR(16)</td></tr>
      <tr><td align="left">duration_minutes</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">timer_duration_seconds</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">sort_order</td><td align="left">SMALLINT</td></tr>
    </table>>];

  api_sessiontemplate [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#16A34A"><font color="white"><b>api_sessiontemplate</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">level_key</td><td align="left">VARCHAR(32)</td></tr>
      <tr><td align="left">title</td><td align="left">VARCHAR(150)</td></tr>
      <tr><td align="left">duration_minutes</td><td align="left">INTEGER</td></tr>
      <tr><td align="left">color_hex</td><td align="left">VARCHAR(16)</td></tr>
      <tr><td align="left">sort_order</td><td align="left">SMALLINT</td></tr>
    </table>>];

  api_tiptemplate [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white">
      <tr><td colspan="2" bgcolor="#16A34A"><font color="white"><b>api_tiptemplate</b></font></td></tr>
      <tr><td align="left">id</td><td align="left">BIGINT PK</td></tr>
      <tr><td align="left">text</td><td align="left">VARCHAR(255)</td></tr>
      <tr><td align="left">icon</td><td align="left">VARCHAR(16)</td></tr>
      <tr><td align="left">sort_order</td><td align="left">SMALLINT</td></tr>
    </table>>];

  auth_user -> api_profile;
  api_profile -> api_devicestatus;
  api_profile -> api_session;
  api_profile -> api_userachievement;
  api_achievementtemplate -> api_userachievement;
}
