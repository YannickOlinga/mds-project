// MLD - Modele Logique de Donnees (relationnel) - Perinea
digraph MLD {
  graph [rankdir=LR, splines=ortho, nodesep=0.5, ranksep=1.3, fontname="Helvetica", bgcolor="white", label="MLD - Modele Logique de Donnees (Perinea)", labelloc="t", fontsize=20];
  node  [shape=plaintext, fontname="Helvetica"];
  edge  [arrowhead=crow, arrowtail=none, dir=both, color="#2563EB", penwidth=1.3];

  UTILISATEUR [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#2563EB"><font color="white"><b>UTILISATEUR</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left">username</td></tr>
      <tr><td align="left">email</td></tr>
      <tr><td align="left">password</td></tr>
    </table>>];

  PROFIL [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#2563EB"><font color="white"><b>PROFIL</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left"><i>user_id</i> = UTILISATEUR</td></tr>
      <tr><td align="left">name, email, age</td></tr>
      <tr><td align="left">objective, level_key</td></tr>
      <tr><td align="left">onboarding_completed</td></tr>
      <tr><td align="left">created_at, ...</td></tr>
    </table>>];

  DEVICE_STATUS [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#2563EB"><font color="white"><b>DEVICE_STATUS</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left"><i>profile_id</i> = PROFIL (unique)</td></tr>
      <tr><td align="left">device_name, battery_pct</td></tr>
      <tr><td align="left">signal_level, connected</td></tr>
      <tr><td align="left">updated_at</td></tr>
    </table>>];

  SESSION [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#2563EB"><font color="white"><b>SESSION</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left"><i>profile_id</i> = PROFIL</td></tr>
      <tr><td align="left">title, level_key</td></tr>
      <tr><td align="left">duration_minutes/seconds</td></tr>
      <tr><td align="left">exercises_count, started_at</td></tr>
    </table>>];

  USER_ACHIEVEMENT [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#D97706"><font color="white"><b>USER_ACHIEVEMENT</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left"><i>profile_id</i> = PROFIL</td></tr>
      <tr><td align="left"><i>achievement_id</i> = ACHIEVEMENT_TEMPLATE</td></tr>
      <tr><td align="left">earned, earned_at</td></tr>
      <tr><td align="left">unique(profile_id, achievement_id)</td></tr>
    </table>>];

  ACHIEVEMENT_TEMPLATE [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#16A34A"><font color="white"><b>ACHIEVEMENT_TEMPLATE</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left">code (unique)</td></tr>
      <tr><td align="left">title, description, icon</td></tr>
    </table>>];

  EXERCISE_TEMPLATE [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#16A34A"><font color="white"><b>EXERCISE_TEMPLATE</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left">level_key, name, description</td></tr>
      <tr><td align="left">icon, duration_minutes</td></tr>
      <tr><td align="left">timer_duration_seconds, sort_order</td></tr>
    </table>>];

  SESSION_TEMPLATE [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#16A34A"><font color="white"><b>SESSION_TEMPLATE</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left">level_key, title</td></tr>
      <tr><td align="left">duration_minutes, color_hex</td></tr>
      <tr><td align="left">sort_order</td></tr>
    </table>>];

  TIP_TEMPLATE [label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4" bgcolor="white">
      <tr><td bgcolor="#16A34A"><font color="white"><b>TIP_TEMPLATE</b></font></td></tr>
      <tr><td align="left"><b>#</b> id</td></tr>
      <tr><td align="left">text, icon, sort_order</td></tr>
    </table>>];

  // Relations (cote crow = cote "plusieurs")
  UTILISATEUR -> PROFIL;
  PROFIL -> DEVICE_STATUS;
  PROFIL -> SESSION;
  PROFIL -> USER_ACHIEVEMENT;
  ACHIEVEMENT_TEMPLATE -> USER_ACHIEVEMENT;
}
